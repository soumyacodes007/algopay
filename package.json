{
    "name": "algopay",
    "version": "0.1.0",
    "type": "module",
    "description": "Agentic payment wallet for Algorand — Stripe for AI Agents",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "algopay": "./dist/cli.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsx watch src/cli.ts",
        "dev:server": "tsx watch src/server/server.ts",
        "start": "node dist/cli.js",
        "start:server": "node dist/server/server.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:connections": "vitest run --reporter=verbose tests/connections/",
        "test:auth": "vitest run --reporter=verbose tests/auth/",
        "lint": "eslint src/",
        "clean": "rimraf dist"
    },
    "keywords": [
        "algorand",
        "agentic",
        "payments",
        "x402",
        "wallet",
        "AI",
        "DePIN"
    ],
    "author": "soumyacodes007",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/soumyacodes007/algopay.git"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.0",
        "@sendgrid/mail": "^8.1.6",
        "algosdk": "^3.2.0",
        "chalk": "^5.4.1",
        "commander": "^13.1.0",
        "conf": "^13.1.0",
        "dotenv": "^16.5.0",
        "express": "^5.2.1",
        "ioredis": "^5.10.0",
        "jsonwebtoken": "^9.0.3",
        "open": "^10.1.0",
        "ora": "^8.2.0",
        "uuid": "^13.0.0",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.15.0",
        "@types/uuid": "^10.0.0",
        "@types/ws": "^8.18.1",
        "pytest": "^1.0.0",
        "rimraf": "^6.0.1",
        "tsx": "^4.19.4",
        "typescript": "^5.8.0",
        "vitest": "^3.1.0"
    }
}
